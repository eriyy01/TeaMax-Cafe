---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const siteUrl = Astro.site?.origin ?? "https://teamaxcafe.com";
const { title = "TeaMax Cafe Bilaspur — Where Every Sip Becomes a Memory" } = Astro.props;
const { description = "Experience the finest coffee, tea, and comfort food in Bilaspur. Premium café with warm ambience, perfect for friends, dates, and work sessions." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href={Astro.site?.pathname ?? "/"} />
    <meta name="theme-color" content="#121212" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/images/og-image.jpg`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={siteUrl} />
    <meta name="apple-mobile-web-app-capable" content="yes" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" />
    </noscript>

    <style>
      @font-face {
        font-family: 'Playfair Display';
        font-display: swap;
        src: local('Playfair Display'), local('Georgia');
      }
      @font-face {
        font-family: 'Inter';
        font-display: swap;
        src: local('Inter'), local('Segoe UI'), local('system-ui');
      }
    </style>

    <link rel="preload" as="image" href="images/hero-bg.jpg" fetchpriority="high" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CafeOrCoffeeShop",
      "name": "TeaMax Cafe Bilaspur",
      "image": `${siteUrl}/images/og-image.jpg`,
      "url": siteUrl,
      "telephone": "+917047505158",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Tiranga Chowk, SH7, Balram Talkies Road, near Padmashree Shyamlal Chaturvedi Smart Road, Sindhi Colony",
        "addressLocality": "Bilaspur",
        "addressRegion": "Chhattisgarh",
        "postalCode": "495001",
        "addressCountry": "IN"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "09:00",
        "closes": "22:00"
      },
      "priceRange": "₹1–₹200",
      "servesCuisine": ["Coffee","Tea","Snacks","Fast Food","Desserts"]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
