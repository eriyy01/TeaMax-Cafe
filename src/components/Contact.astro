---

---

<section id="contact" class="section-padding relative">
  <div class="container-cafe">
    <div class="text-center mb-12 reveal">
      <span class="section-label">Get in Touch</span>
      <h2 class="section-title">
        We'd Love to <span class="text-gradient">Hear From You</span>
      </h2>
      <p class="section-subtitle mx-auto">
        Have a question, feedback, or just want to say hello? Drop us a message.
      </p>
    </div>

    <div class="max-w-2xl mx-auto reveal">
      <form
        class="glass-card p-8 space-y-6"
        action="https://formspree.io/f/xqapwqzw"
        method="POST"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-cream/80 mb-2">Your Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-xl bg-warm-black border border-white/10 text-cream placeholder-muted focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
            placeholder="Enter your name"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-cream/80 mb-2">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            autocomplete="tel"
            inputmode="numeric"
            pattern="[0-9+\-\s]{10,15}"
            class="w-full px-4 py-3 rounded-xl bg-warm-black border border-white/10 text-cream placeholder-muted focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
            placeholder="Enter your phone number"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-cream/80 mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full px-4 py-3 rounded-xl bg-warm-black border border-white/10 text-cream placeholder-muted focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors resize-none"
            placeholder="Tell us what's on your mind..."
          ></textarea>
        </div>

        <button type="submit" class="btn-primary w-full focus:outline-none focus:ring-2 focus:ring-gold/50">
          Send Message
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </button>
      </form>

      <div class="mt-8 text-center">
        <p class="text-muted mb-2">Or reach us directly at</p>
        <a href="tel:+917047505158" class="text-gold hover:text-gold-light transition-colors text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-gold/50 rounded">+91 7047505158</a>
      </div>
    </div>
  </div>
</section>
