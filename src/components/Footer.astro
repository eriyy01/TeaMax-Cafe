---
const quickLinks = ["Home", "About", "Menu", "Gallery", "Reviews", "Visit", "Contact"];
---

<footer class="relative" role="contentinfo">
  <div class="absolute inset-0 bg-gradient-to-b from-warm-black via-charcoal/50 to-warm-black"></div>

  <div class="relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-20 lg:py-28">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-8">
          <div class="lg:col-span-5">
            <h3 class="font-heading text-4xl lg:text-5xl font-bold text-gradient mb-6">TeaMax</h3>
            <p class="text-muted text-base leading-relaxed max-w-sm mb-8">
              Where Every Sip Becomes a Memory. Premium café experience crafted with passion in the heart of Bilaspur.
            </p>
            <div class="flex gap-4">
              <a href="https://instagram.com/teamaxcafe" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-muted hover:text-gold hover:border-gold/30 hover:shadow-[0_0_20px_rgba(201,168,76,0.15)] transition-all duration-400 focus:outline-none focus:ring-2 focus:ring-gold/50" aria-label="Follow us on Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/></svg>
              </a>
              <a href="https://facebook.com/teamaxcafe" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-muted hover:text-gold hover:border-gold/30 hover:shadow-[0_0_20px_rgba(201,168,76,0.15)] transition-all duration-400 focus:outline-none focus:ring-2 focus:ring-gold/50" aria-label="Follow us on Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </div>
          </div>

          <div class="lg:col-span-3">
            <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6">Quick Links</h4>
            <ul class="space-y-3">
              {quickLinks.map((link) => (
                <li>
                  <a href={link === "Home" ? "#home" : `#${link.toLowerCase()}`} class="text-sm text-muted hover:text-cream transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-gold/50 rounded">
                    {link}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6">Hours</h4>
            <div class="space-y-2">
              <p class="text-sm text-muted">Open Daily</p>
              <p class="text-sm text-cream font-medium">9 AM — 10 PM</p>
            </div>
          </div>

          <div class="lg:col-span-2">
            <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6">Contact</h4>
            <div class="space-y-2">
              <a href="tel:+917047505158" class="text-sm text-cream font-medium hover:text-gold transition-colors block">+91 7047505158</a>
              <p class="text-sm text-muted leading-relaxed">Sindhi Colony,<br/>Bilaspur, CG</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-muted/60">&copy; {new Date().getFullYear()} TeaMax Cafe Bilaspur. All rights reserved.</p>
          <a href="#home" class="group text-xs text-muted/60 hover:text-gold transition-colors flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-gold/50 rounded">
            <span>Back to top</span>
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
