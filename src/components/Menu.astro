---
import MenuCard from "./MenuCard.astro";
import { menuItems, categories } from "../data/menu";

const signatureItems = menuItems.filter((item) => item.signature);
---

<section id="menu" class="section-padding relative">
  <div class="container-cafe">
    <div class="text-center mb-12 reveal">
      <span class="section-label">Our Menu</span>
      <h2 class="section-title">
        Crafted with <span class="text-gradient">Passion</span>
      </h2>
      <p class="section-subtitle mx-auto">
        From our signature Masala Chai to freshly made sandwiches — every item is made to order, made with love.
      </p>
    </div>

    {signatureItems.length > 0 && (
      <div class="mb-16 reveal">
        <h3 class="font-heading text-2xl md:text-3xl text-cream mb-8 text-center">
          ✦ Signature Specials
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {signatureItems.slice(0, 3).map((item) => (
            <div class="glass-card overflow-hidden group cursor-pointer relative">
              <div class="h-64 overflow-hidden">
                <img src={item.image} alt={item.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-warm-black/90 via-warm-black/30 to-transparent flex flex-col justify-end p-6">
                <h4 class="font-heading text-xl font-semibold text-cream mb-1">{item.name}</h4>
                <p class="text-sm text-cream/70 mb-3">{item.description}</p>
                <div class="flex items-center gap-3">
                  <span class="text-gold font-bold text-lg">{item.price}</span>
                  <span class="text-xs text-gold/60 uppercase tracking-wider">Chef's Pick</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="flex flex-wrap justify-center gap-3 mb-10 reveal" role="tablist" aria-label="Menu categories">
      <button class="menu-tab active px-5 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-gold text-warm-black" data-filter="all" role="tab" aria-selected="true" aria-controls="menu-grid">All</button>
      {categories.map((cat) => (
        <button class="menu-tab px-5 py-2 rounded-full text-sm font-medium transition-all duration-300 glass text-cream/70 hover:text-gold hover:border-gold/30" data-filter={cat} role="tab" aria-selected="false" aria-controls="menu-grid">
          {cat}
        </button>
      ))}
    </div>

    <div id="menu-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" role="tabpanel">
      {menuItems.map((item) => (
        <MenuCard
          name={item.name}
          description={item.description}
          price={item.price}
          image={item.image}
          category={item.category}
          signature={item.signature}
        />
      ))}
    </div>
  </div>
</section>

<style is:global>
  .menu-tab.active {
    background: linear-gradient(135deg, #c9a84c 0%, #a8882e 100%);
    color: #121212;
  }
</style>
