---

---

<section id="visit" class="section-padding relative">
  <div class="container-cafe">
    <div class="text-center mb-12 reveal">
      <span class="section-label">Visit Us</span>
      <h2 class="section-title">
        We'd Love to <span class="text-gradient">Welcome You</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div class="space-y-6 reveal-left">
        <div class="glass-card p-6">
          <h3 class="font-heading text-xl text-cream mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Address
          </h3>
          <p class="text-muted leading-relaxed">
            Tiranga Chowk, SH7, Balram Talkies Road,<br />
            near Padmashree Shyamlal Chaturvedi Smart Road,<br />
            Sindhi Colony, Bilaspur, Chhattisgarh 495001
          </p>
        </div>

        <div class="glass-card p-6">
          <h3 class="font-heading text-xl text-cream mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Open Hours
          </h3>
          <p class="text-muted">Open Daily · Closes <time datetime="22:00">10 PM</time></p>
        </div>

        <div class="glass-card p-6">
          <h3 class="font-heading text-xl text-cream mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Price Range
          </h3>
          <p class="text-muted">₹1 – ₹200</p>
        </div>

        <div class="glass-card p-6">
          <h3 class="font-heading text-xl text-cream mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Services
          </h3>
          <div class="flex flex-wrap gap-3">
            <span class="px-4 py-2 rounded-full text-sm bg-gold/10 text-gold border border-gold/20">Dine In</span>
            <span class="px-4 py-2 rounded-full text-sm bg-gold/10 text-gold border border-gold/20">Takeaway</span>
            <span class="px-4 py-2 rounded-full text-sm bg-gold/10 text-gold border border-gold/20">Kerbside Pickup</span>
            <span class="px-4 py-2 rounded-full text-sm bg-surface-light text-muted border border-white/10">No Contact Delivery</span>
          </div>
        </div>

        <div class="flex gap-4">
          <a href="tel:+917047505158" class="btn-primary flex-1 text-center">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call Now
          </a>
          <a
            href="https://maps.google.com/?q=TeaMax+Cafe+Bilaspur+Tiranga+Chowk"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline flex-1 text-center"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Directions
          </a>
        </div>
      </div>

      <div class="rounded-2xl overflow-hidden h-[400px] lg:h-[600px] glass reveal-right">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3718.5123456789!2d82.134!3d22.0896!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zQmlsYXNwdXIgQ2l0eQ!5e0!3m2!1sen!2sin!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="TeaMax Cafe Location"
        ></iframe>
      </div>
    </div>
  </div>
</section>
