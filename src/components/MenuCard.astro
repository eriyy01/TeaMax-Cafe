---
export interface Props {
  name: string;
  description: string;
  price: string;
  image: string;
  category: string;
  signature?: boolean;
}

const { name, description, price, image, category, signature } = Astro.props;
---

<div
  class="menu-item glass-card overflow-hidden group cursor-pointer"
  data-category={category}
  role="article"
  tabindex="0"
>
  <div class="relative h-48 overflow-hidden bg-surface">
    <img
      src={image}
      alt={`${name} - ${description}`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
      decoding="async"
      width="600"
      height="400"
    />
    {signature && (
      <span class="absolute top-3 right-3 bg-gold text-warm-black text-xs font-semibold px-3 py-1 rounded-full">
        Signature
      </span>
    )}
  </div>
  <div class="p-5">
    <h3 class="font-heading text-lg font-semibold text-cream mb-1">{name}</h3>
    <p class="text-sm text-muted mb-3 line-clamp-2">{description}</p>
    <div class="flex items-center justify-between">
      <span class="text-gold font-semibold text-lg">{price}</span>
      <button
        class="text-xs text-cream/50 hover:text-gold transition-colors focus:outline-none focus:ring-2 focus:ring-gold/50 rounded px-2 py-1"
        onclick="alert('Order feature coming soon!')"
        aria-label={`Order ${name}`}
      >
        Order Now
      </button>
    </div>
  </div>
</div>
